{
  "kind": "singleType",
  "collectionName": "contacts",
  "info": {
    "singularName": "contact",
    "pluralName": "contacts",
    "displayName": "Contact"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "organisationName": {
      "type": "string",
      "required": true
    },
    "organisationNumber": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true,
      "default": "meile@garmeres.com"
    },
    "address": {
      "type": "text",
      "required": true
    },
    "vipps": {
      "type": "string",
      "required": true
    },
    "bankAccount": {
      "type": "string",
      "required": true
    },
    "iban": {
      "type": "string",
      "required": true
    },
    "swift": {
      "type": "string",
      "required": true
    }
  }
}
