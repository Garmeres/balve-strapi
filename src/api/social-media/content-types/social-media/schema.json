{
  "kind": "collectionType",
  "collectionName": "social_medias",
  "info": {
    "singularName": "social-media",
    "pluralName": "social-medias",
    "displayName": "Social Media"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "minLength": 3,
      "required": true,
      "unique": true
    },
    "Icon": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "URL": {
      "type": "string",
      "minLength": 5,
      "required": true
    },
    "Index": {
      "type": "integer",
      "required": true,
      "default": 0
    }
  }
}
